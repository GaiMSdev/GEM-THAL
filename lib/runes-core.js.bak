const fs = require('fs');
const path = require('path');
const os = require('os');

const HOME = os.homedir();
const VALID_MODES = ['lite', 'full', 'ultra', 'hybrid', 'wenyan', 'off'];
const TMP_DIRS = [
  process.env.GEMINI_CONFIG_DIR ? path.join(process.env.GEMINI_CONFIG_DIR, "tmp") : path.join(HOME, ".gemini", "tmp"),
  path.join(HOME, ".config", "opencode", "tmp"),
  path.join(HOME, ".claude", "tmp")
];
const SKIP_DIRS = new Set(["background-processes", "bin"]);

function getFlagPath() {
  if (process.env.GEMINI_CONFIG_DIR) return path.join(process.env.GEMINI_CONFIG_DIR, '.compress-active');
  if (process.cwd().includes('.config/opencode') || process.env.OPENCODE_CONFIG_DIR) return path.join(HOME, '.config', 'opencode', '.runes-active');
  if (process.cwd().includes('.claude')) return path.join(HOME, '.claude', '.caveman-active');
  return path.join(HOME, '.gemini', '.compress-active');
}

function readFlag() {
  const p = getFlagPath();
  try {
    if (!fs.existsSync(p)) return null;
    const val = fs.readFileSync(p, 'utf8').trim();
    return VALID_MODES.includes(val) ? val : null;
  } catch (e) { return null; }
}

function writeFlag(mode) {
  const p = getFlagPath();
  try {
    const dir = path.dirname(p);
    if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
    fs.writeFileSync(p, mode, 'utf8');
  } catch (e) {}
}

function removeFlag() {
  try {
    const p = getFlagPath();
    if (fs.existsSync(p)) fs.unlinkSync(p);
  } catch (e) {}
}

function getLatestSession() {
  let best = null;
  let bestMtime = 0;
  for (const tmpDir of TMP_DIRS) {
    if (!fs.existsSync(tmpDir)) continue;
    try {
      for (const dir of fs.readdirSync(tmpDir)) {
        if (SKIP_DIRS.has(dir)) continue;
        const fullPath = path.join(tmpDir, dir);
        if (!fs.statSync(fullPath).isDirectory()) continue;
        const chatsDir = path.join(fullPath, "chats");
        if (!fs.existsSync(chatsDir)) continue;
        for (const file of fs.readdirSync(chatsDir)) {
          if (!file.startsWith("session-") || !file.endsWith(".jsonl")) continue;
          const fp = path.join(chatsDir, file);
          const { mtimeMs } = fs.statSync(fp);
          if (mtimeMs > bestMtime) { bestMtime = mtimeMs; best = fp; }
        }
      }
    } catch (e) {}
  }
  return best;
}

function getStatsReport() {
  const sessionFile = getLatestSession();
  const acc = { cached: 0, input: 0, output: 0, thoughts: 0, tool: 0, total: 0, model: "N/A" };
  if (sessionFile) {
    try {
      const content = fs.readFileSync(sessionFile, "utf8").trim();
      for (const line of content.split("\n")) {
        try {
          const entry = JSON.parse(line);
          if (!entry.tokens) continue;
          const t = entry.tokens;
          acc.cached   += t.cached_tokens || t.cached || 0;
          acc.input    += t.input_tokens  || t.input  || 0;
          acc.output   += t.output_tokens || t.output || 0;
          acc.thoughts += t.thoughts || 0;
          acc.tool     += t.tool_tokens   || t.tool   || 0;
          acc.total    += t.total_tokens  || t.total  || 0;
          if (entry.model) acc.model = entry.model;
        } catch (e) {}
      }
    } catch (e) {}
  }

  const mode = readFlag() || "off";
  const COMPRESSION = { lite: 0.35, full: 0.75, ultra: 0.88, hybrid: 0.92, wenyan: 0.85 };
  const ratio = COMPRESSION[mode] || 0;
  const estSaved = (ratio > 0 && acc.output > 0) ? Math.round(acc.output * (ratio / (1 - ratio))) : 0;

  let report = "RUNES PRECISION STATS\n---------------------\n";
  report += `Model:      ${acc.model}\n`;
  report += `Mode:       ${mode.toUpperCase()}\n`;
  if (acc.cached > 0)   report += `Cached:     ${acc.cached.toLocaleString()} tokens\n`;
  if (acc.thoughts > 0) report += `Thoughts:   ${acc.thoughts.toLocaleString()} tokens\n`;
  if (acc.tool > 0)     report += `Tool:       ${acc.tool.toLocaleString()} tokens\n`;
  report += `Input:      ${acc.input.toLocaleString()} tokens\n`;
  report += `Output:     ${acc.output.toLocaleString()} tokens\n`;
  report += `Total:      ${(acc.input + acc.output).toLocaleString()} tokens\n`;
  if (estSaved > 0) {
    report += `Est. Saved: ${estSaved.toLocaleString()} tokens (${Math.round(ratio * 100)}% saving)\n`;
    report += `Full Val:   ${(acc.output + estSaved).toLocaleString()} tokens equivalent\n`;
  }
  return report.trim();
}

function getPromptInstructions(mode) {
  if (mode === 'lite') return "COMPRESS LITE: Drop filler. Keep detail.";
  if (mode === 'ultra') return "COMPRESS ULTRA: Abbrev prose (DB/auth/cfg/req/res/fn/impl/ctx/err). → for causality. Strip conjunctions. NOT→DO contrastive. NEVER invent symbols.";
  if (mode === 'hybrid') return "COMPRESS HYBRID: Combined technique. Broken-English + abbrev. Use 'Me' + subject/verb fragment. Dense logic via →. Maximize token-savings.";
  return "COMPRESS FULL: Drop articles. Fragments OK.";
}

function getStatusLine(mode, errorMsg = "", context = {}) {
  const badgeName = "RUNES";
  if (errorMsg) return "🔴 [" + badgeName + ":CRITICAL_ERR" + errorMsg + "] -> AI REPAIRING...";
  if (context.isSensitive && mode !== 'lite') return "🟡 [" + badgeName + ":SENSITIVE] -> AI MITIGATING...";
  return "🟢 [" + badgeName + ":" + mode.toUpperCase() + "]";
}

module.exports = { readFlag, writeFlag, removeFlag, getPromptInstructions, getStatusLine, getStatsReport, VALID_MODES };
